{
  "_comment": "Copy to ~/.mcp.json (or pass --config <this-file>) after editing the absolute paths. coffee runs the example script directly; triage uses the burr-mcp CLI with --app-dir to make examples/ importable.",
  "mcpServers": {
    "burr-mcp-coffee": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "/ABSOLUTE/PATH/TO/burr-mcp",
        "run",
        "python",
        "examples/coffee_order.py"
      ]
    },
    "burr-mcp-triage": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "/ABSOLUTE/PATH/TO/burr-mcp",
        "run",
        "burr-mcp",
        "serve",
        "triage:build_application",
        "--app-dir",
        "examples"
      ]
    }
  }
}
