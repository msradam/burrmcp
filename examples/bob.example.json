{
  "_comment": "Several burrmcp example servers wired up for IBM Bob (IDE + Shell share this schema). Copy to .bob/mcp.json in your project root, or to ~/.bob/mcp_settings.json for global. Replace /ABSOLUTE/PATH/TO/burrmcp with your checkout. The alwaysAllow lists pre-approve burrmcp's four meta tools so Bob doesn't prompt for permission on every FSM step. See https://bob.ibm.com/docs/ide/configuration/mcp/mcp-in-bob and https://bob.ibm.com/docs/shell/configuration/mcp/mcp-bobshell.",
  "mcpServers": {
    "coffee": {
      "command": "uv",
      "args": [
        "--directory",
        "/ABSOLUTE/PATH/TO/burrmcp",
        "run",
        "burrmcp",
        "serve",
        "coffee_order:build_application",
        "--app-dir",
        "examples"
      ],
      "alwaysAllow": ["step", "reset_session", "fork_at", "fork_from_past"]
    },
    "adventure": {
      "command": "uv",
      "args": [
        "--directory",
        "/ABSOLUTE/PATH/TO/burrmcp",
