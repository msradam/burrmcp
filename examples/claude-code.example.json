{
  "_comment": "Several burrmcp example servers wired up for Claude Code. Copy this to your project's .mcp.json (or paste into ~/.claude.json under mcpServers) after editing the absolute path. Then run `claude` from this project and use /mcp to confirm. Each server is self-contained: no APIs, no shell, no auth. Just prompt and try to break the gates.",
  "mcpServers": {
    "coffee": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "/ABSOLUTE/PATH/TO/burrmcp",
        "run",
        "burrmcp",
        "serve",
        "coffee_order:build_application",
        "--app-dir",
        "examples"
      ]
    },
