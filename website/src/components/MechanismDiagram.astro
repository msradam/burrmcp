---
// An illustrative incident-response FSM, rendered the way the v14 brand spec
// shows it: a state diagram + the audit log it produces. The log fields are
// the real Burr-tracker shape (ts / action / from -> to / reason / outcome);
// no hash-chain or tamper-evidence is claimed, because Theodosia does not do
// that. The workflow itself is illustrative.
---

<div class="thd-mech">
  <div class="thd-mech-head">
    <div class="thd-mech-title">incident.app · visual</div>
    <div class="thd-mech-pills">
      <span class="thd-pill ok">⊢ 4 allowed</span>
      <span class="thd-pill no">○ 1 refused</span>
      <span class="thd-pill cur">★ current: engaged</span>
    </div>
  </div>

  <div class="thd-mech-body">
    <div class="thd-diagram">
      <svg viewBox="0 0 720 360" fill="none" role="img" aria-label="State diagram: triaged to engaged to verified to resolved, with close_incident refused from engaged">
        <defs>
          <marker id="ok-arr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10 z" fill="#573e8a"></path>
          </marker>
          <marker id="no-arr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10 z" fill="#7a3c4a"></path>
          </marker>
        </defs>

        <g><rect x="14" y="40" width="120" height="60" rx="10" fill="#ffffff" stroke="#d4d4cf" stroke-width="1"></rect><text x="74" y="66" text-anchor="middle" font-family="Inria Serif" font-size="16" font-weight="600" fill="#0a0a0a">triaged</text><text x="74" y="84" text-anchor="middle" font-family="JetBrains Mono" font-size="9.5" fill="#7a7a76" letter-spacing="1.2">STATE 01</text></g>
        <line x1="134" y1="70" x2="200" y2="70" stroke="#573e8a" stroke-width="1.6" marker-end="url(#ok-arr)"></line>
        <text x="167" y="60" text-anchor="middle" font-family="JetBrains Mono" font-size="11" fill="#573e8a" font-weight="500">page_oncall</text>

        <g><rect x="200" y="40" width="130" height="60" rx="10" fill="#fcefd5" stroke="#ea9d34" stroke-width="1.6"></rect><text x="265" y="66" text-anchor="middle" font-family="Inria Serif" font-size="16" font-weight="600" fill="#0a0a0a">engaged</text><text x="265" y="84" text-anchor="middle" font-family="JetBrains Mono" font-size="9.5" font-weight="600" fill="#9c6b1a" letter-spacing="1.8">★ CURRENT</text></g>
        <line x1="330" y1="70" x2="400" y2="70" stroke="#573e8a" stroke-width="1.6" marker-end="url(#ok-arr)"></line>
        <text x="365" y="60" text-anchor="middle" font-family="JetBrains Mono" font-size="11" fill="#573e8a" font-weight="500">verify</text>

        <g><rect x="400" y="40" width="120" height="60" rx="10" fill="#ffffff" stroke="#d4d4cf" stroke-width="1"></rect><text x="460" y="66" text-anchor="middle" font-family="Inria Serif" font-size="16" font-weight="600" fill="#0a0a0a">verified</text><text x="460" y="84" text-anchor="middle" font-family="JetBrains Mono" font-size="9.5" fill="#7a7a76" letter-spacing="1.2">STATE 03</text></g>
        <line x1="520" y1="70" x2="580" y2="70" stroke="#573e8a" stroke-width="1.6" marker-end="url(#ok-arr)"></line>
        <text x="550" y="60" text-anchor="middle" font-family="JetBrains Mono" font-size="11" fill="#573e8a" font-weight="500">resolve</text>

        <g><rect x="580" y="40" width="120" height="60" rx="10" fill="#ffffff" stroke="#d4d4cf" stroke-width="1"></rect><text x="640" y="66" text-anchor="middle" font-family="Inria Serif" font-size="16" font-weight="600" fill="#0a0a0a">resolved</text><text x="640" y="84" text-anchor="middle" font-family="JetBrains Mono" font-size="9.5" fill="#7a7a76" letter-spacing="1.2">STATE 04</text></g>

        <path d="M 265 100 L 265 180" stroke="#7a3c4a" stroke-width="1.6" stroke-dasharray="4 3" fill="none" marker-end="url(#no-arr)"></path>
        <text x="280" y="130" font-family="JetBrains Mono" font-size="11" fill="#7a3c4a" font-weight="600">close_incident</text>
        <text x="280" y="148" font-family="Inria Serif" font-style="italic" font-size="13" fill="#7a3c4a">refused</text>
        <text x="280" y="164" font-family="JetBrains Mono" font-size="10" fill="#7a7a76">not reachable from engaged; requires verified</text>

        <g transform="translate(210, 205)">
          <rect x="0" y="0" width="118" height="44" rx="8" fill="#f6ebed" stroke="#7a3c4a" stroke-width="1" stroke-dasharray="3 2"></rect>
          <text x="59" y="20" text-anchor="middle" font-family="JetBrains Mono" font-size="10" fill="#7a3c4a" font-weight="600" letter-spacing="1">NO STATE CHANGE</text>
          <text x="59" y="34" text-anchor="middle" font-family="Inria Serif" font-style="italic" font-size="11" fill="#7a7a76">recorded · not advanced</text>
        </g>

        <g><rect x="580" y="280" width="120" height="60" rx="10" fill="#ffffff" stroke="#d4d4cf" stroke-width="1" stroke-dasharray="2 2"></rect><text x="640" y="306" text-anchor="middle" font-family="Inria Serif" font-size="16" font-weight="600" fill="#0a0a0a">closed</text><text x="640" y="324" text-anchor="middle" font-family="JetBrains Mono" font-size="9.5" fill="#7a7a76" letter-spacing="1.2">TERMINAL</text></g>
        <line x1="640" y1="100" x2="640" y2="276" stroke="#573e8a" stroke-width="1.6" marker-end="url(#ok-arr)"></line>
        <text x="655" y="190" font-family="JetBrains Mono" font-size="11" fill="#573e8a" font-weight="500">archive</text>
      </svg>
    </div>

    <div class="thd-legend">
      <div class="thd-legend-row"><div class="g ok">⊢</div><div><strong>allowed.</strong> A transition defined in the graph. State advances and the step is recorded.</div></div>
      <div class="thd-legend-row"><div class="g no">○</div><div><strong>refused.</strong> The requested action is not reachable from the current state. It comes back as a structured refusal with the reachable actions, and state does not advance.</div></div>
      <div class="thd-legend-row"><div class="g cur">★</div><div><strong>current.</strong> The workflow's persisted state, on the server. Theodosia is the source of truth; the agent's idea of the state is incidental.</div></div>
    </div>
  </div>

  <div class="thd-audit">
    <div class="thd-audit-lbl">theodosia://history · sequential excerpt</div>
    <div class="thd-audit-head"><div>timestamp</div><div>action</div><div>from → to</div><div>reason</div><div>outcome</div></div>
    <div class="thd-audit-row"><div class="ts">2026-05-25T14:30:12Z</div><div class="act">page_oncall</div><div class="ft">triaged <span class="ar">→</span> engaged</div><div class="rsn">·</div><div class="out ok">allowed</div></div>
    <div class="thd-audit-row refused"><div class="ts">2026-05-25T14:31:45Z</div><div class="act">close_incident</div><div class="ft">engaged <span class="ar no">→</span> ·</div><div class="rsn">not reachable from engaged; requires verified</div><div class="out no">refused</div></div>
    <div class="thd-audit-row"><div class="ts">2026-05-25T14:33:20Z</div><div class="act">verify</div><div class="ft">engaged <span class="ar">→</span> verified</div><div class="rsn">·</div><div class="out ok">allowed</div></div>
    <div class="thd-audit-row"><div class="ts">2026-05-25T14:40:01Z</div><div class="act">resolve</div><div class="ft">verified <span class="ar">→</span> resolved</div><div class="rsn">·</div><div class="out ok">allowed</div></div>
  </div>
</div>

<style>
  .thd-mech {
    background: var(--thd-sheet, #fff);
    border: 1px solid var(--thd-edge, #e6e6e2);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(10, 10, 10, 0.04), 0 4px 12px rgba(10, 10, 10, 0.04);
    margin: 2rem 0;
    color: #0a0a0a;
  }
  .thd-mech-head {
    padding: 14px 24px;
    border-bottom: 1px solid var(--thd-edge, #e6e6e2);
    background: var(--thd-raised, #f5f5f3);
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 12px;
  }
  .thd-mech-title { font-family: var(--thd-sans); font-size: 14px; font-weight: 600; color: #0a0a0a; }
  .thd-mech-pills { display: flex; gap: 8px; flex-wrap: wrap; }
  .thd-pill {
    font-family: var(--thd-mono); font-size: 10.5px; padding: 4px 10px;
    border-radius: 999px; letter-spacing: 0.04em;
    background: #fff; border: 1px solid var(--thd-edge, #e6e6e2); color: #7a7a76;
  }
  .thd-pill.ok { color: #573e8a; border-color: rgba(87,62,138,0.2); background: #efebf7; }
  .thd-pill.no { color: #7a3c4a; border-color: rgba(122,60,74,0.18); background: #f6ebed; }
  .thd-pill.cur { color: #9c6b1a; border-color: rgba(234,157,52,0.3); background: #fcefd5; }

  .thd-mech-body {
    padding: 32px 28px; display: grid; grid-template-columns: 1.5fr 1fr;
    gap: 36px; align-items: center;
  }
  .thd-diagram svg { width: 100%; height: auto; display: block; }
  .thd-legend { display: flex; flex-direction: column; gap: 16px; }
  .thd-legend-row {
    display: grid; grid-template-columns: 24px 1fr; gap: 12px; align-items: start;
    font-family: var(--thd-sans); font-size: 13.5px; line-height: 1.5; color: #3a3a38;
  }
  .thd-legend-row .g { font-family: var(--thd-mono); font-weight: 600; text-align: center; }
  .thd-legend-row .g.ok { color: #573e8a; }
  .thd-legend-row .g.no { color: #7a3c4a; }
  .thd-legend-row .g.cur { color: #9c6b1a; }
  .thd-legend-row strong { color: #0a0a0a; font-weight: 600; }

  .thd-audit { border-top: 1px solid var(--thd-edge, #e6e6e2); font-family: var(--thd-mono); background: var(--thd-paper, #fafafa); }
  .thd-audit-lbl { padding: 12px 24px 9px; font-size: 10px; color: #7a7a76; letter-spacing: 0.16em; text-transform: uppercase; border-bottom: 1px solid var(--thd-edge, #e6e6e2); }
  .thd-audit-head, .thd-audit-row { display: grid; grid-template-columns: 170px 150px 160px 1fr 90px; gap: 16px; padding: 10px 24px; align-items: baseline; }
  .thd-audit-head { font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: #7a7a76; border-bottom: 1px solid var(--thd-edge, #e6e6e2); background: var(--thd-raised, #f5f5f3); }
  .thd-audit-row { font-size: 12px; color: #3a3a38; border-bottom: 1px solid var(--thd-edge, #e6e6e2); line-height: 1.45; }
  .thd-audit-row:last-child { border-bottom: 0; }
  .thd-audit-row .ts { color: #7a7a76; }
  .thd-audit-row .act { color: #0a0a0a; font-weight: 500; }
  .thd-audit-row.refused .act { color: #7a3c4a; }
  .thd-audit-row .ft .ar { color: #573e8a; padding: 0 4px; font-weight: 600; }
  .thd-audit-row .ft .ar.no { color: #7a3c4a; }
  .thd-audit-row .rsn { color: #7a7a76; font-size: 11px; }
  .thd-audit-row .out { font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; font-size: 10px; padding: 3px 8px; border-radius: 999px; justify-self: end; }
  .thd-audit-row .out.ok { color: #573e8a; background: #efebf7; }
  .thd-audit-row .out.no { color: #7a3c4a; background: #f6ebed; }

  @media (max-width: 720px) {
    .thd-mech-body { grid-template-columns: 1fr; }
    .thd-audit-head, .thd-audit-row { grid-template-columns: 1fr 1fr; gap: 8px; }
    .thd-audit-head div:nth-child(n+3), .thd-audit-row div:nth-child(n+3):not(.out) { display: none; }
  }
</style>
