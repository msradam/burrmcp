---
/**
 * ContentPanel override: appends the page-meta strip at the end of the page
 * with just VERSION (sourced from `lib/site.ts`) and SOURCE (a GitHub link
 * to the markdown file). UPDATED and READ were removed because they were
 * hardcoded identically on every page and read as a lie to attentive readers;
 * if you want them back, wire UPDATED to git mtime or frontmatter, and READ
 * to a real word-count estimate.
 *
 * Starlight calls ContentPanel multiple times per page (one per section
 * block); the strip only renders on the LAST call via a `:has(~)` selector
 * so it sits at the bottom of the content, not after the title block.
 */
import Default from '@astrojs/starlight/components/ContentPanel.astro';
import { VERSION, REPO_URL } from '../lib/site';

const { entry } = Astro.locals?.starlightRoute ?? { entry: null };
const rawId: string = entry?.id ?? entry?.slug ?? '';
const slug: string = rawId.replace(/\.(md|mdx)$/, '').replace(/^.*\//, '');

const sourcePath = `docs/${slug || 'index'}.md`;
const githubSource = `${REPO_URL}/blob/main/website/src/content/${sourcePath}`;
---

<Default {...Astro.props}>
  <slot />
  <div class="thd-page-meta">
    <span class="item"><span class="k">VERSION</span><span class="v accent">v{VERSION}</span></span>
    <span class="sep">·</span>
    <span class="item"><span class="k">SOURCE</span>
      <a href={githubSource} class="src">{sourcePath}</a>
    </span>
  </div>
</Default>

<style is:global>
  .thd-page-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: var(--thd-mono);
    font-size: 11px;
    color: var(--thd-muted);
    letter-spacing: 0.04em;
    padding: 10px 0 0;
    border-top: 1px solid var(--thd-edge);
    margin-top: 36px;
    flex-wrap: wrap;
    line-height: 1.4;
  }
  .thd-page-meta .item { display: inline-flex; align-items: center; gap: 6px; }
  .thd-page-meta .item .k { color: var(--thd-dim); }
  .thd-page-meta .item .v { color: var(--thd-subtle); font-weight: 500; }
  .thd-page-meta .item .v.accent { color: var(--thd-pine); }
  .thd-page-meta .sep { color: var(--thd-dim); }
  .thd-page-meta .src {
    font-family: var(--thd-mono);
    font-size: 11px;
    color: var(--thd-subtle);
    text-decoration: none;
  }
  .thd-page-meta .src:hover { color: var(--thd-pine); text-decoration: underline; }
  /* Only render the meta strip on the FINAL ContentPanel of a page. Hide it
     on every other panel by checking whether another .content-panel follows. */
  .content-panel:has(~ .content-panel) .thd-page-meta { display: none; }
</style>
